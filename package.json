{
  "name": "mobile-sensor-viewer",
  "version": "1.0.0",
  "description": "Display accelerometer and gyroscope sensor values",
  "type": "module",
  "scripts": {
    "prebuild": "node ./scripts/update-build-number.js",
    "build": "tsc",
    "postbuild": "sh ./scripts/tag-and-push.sh",
    "dev": "tsc --watch",
    "serve": "python3 -m http.server 8080",
    "gh-pages-copy": "sh ./scripts/gh-pages-copy.sh"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
